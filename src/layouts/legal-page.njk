{% extends "./base.njk" %}

{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.productionUrl }}" },
    { "@type": "ListItem", "position": 2, "name": "{{ pageHeading }}", "item": "{{ site.productionUrl }}{{ slug }}/" }
  ]
}
</script>
{% endblock %}

{% block content %}
<section class="section section--padded">
  <div class="container narrow legal-content">
    <h1>{{ pageHeading }}</h1>
    {% if pageEffectiveDate %}<p class="legal-effective">Effective Date: {{ pageEffectiveDate }}</p>{% endif %}
    {% include contentInclude %}
  </div>
</section>
{% endblock %}
