{% extends "./base.njk" %}

{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LegalService",
  "name": "{{ site.name }} — {{ pageTitle }}",
  "url": "{{ site.productionUrl }}{{ slug }}/",
  "description": "{{ pageDescription }}",
  "areaServed": { "@type": "Country", "name": "{{ site.areaServed }}" },
  "telephone": "+1{{ site.defaultPhone }}",
  "email": "{{ site.email }}"
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.productionUrl }}" },
    { "@type": "ListItem", "position": 2, "name": "{{ pageTitle }}", "item": "{{ site.productionUrl }}{{ slug }}/" }
  ]
}
</script>

{% if faqs[slug] %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for f in faqs[slug] %}
    {
      "@type": "Question",
      "name": {{ f.q | dump | safe }},
      "acceptedAnswer": { "@type": "Answer", "text": {{ f.a | dump | safe }} }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
{% endblock %}

{% block content %}
<section class="service-hero">
  <div class="container service-hero_inner">
    <div class="service-hero_copy">
      <p class="hero_eyebrow">
        Call Today!
        <a href="tel:+1{{ site.defaultPhone }}" data-dynamic-phone-tel>
          <span data-dynamic-phone>{{ site.defaultPhoneFormatted }}</span>
        </a>
      </p>
      <h1>{{ pageHeading }}</h1>
      {% if pageSubheading %}<p class="hero_subtitle">{{ pageSubheading }}</p>{% endif %}
    </div>
    <div class="service-hero_form" id="form">
      <script src="/form.min.js?ver=1"></script>
      <div id="ll-form"></div>
    </div>
  </div>
</section>

<section class="section section--padded">
  <div class="container narrow article-content">
    {% include contentInclude %}
  </div>
</section>

{% if faqs[slug] %}
<section class="section section--padded section--alt">
  <div class="container narrow">
    <h2 class="section_heading section_heading--center">Frequently Asked Questions</h2>
    <div class="faqs">
      {% for f in faqs[slug] %}
      <details class="faq">
        <summary class="faq_q">{{ f.q }}</summary>
        <p class="faq_a">{{ f.a }}</p>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<section class="section section--padded section--cta">
  <div class="container">
    <h2>Get Your Free Case Evaluation</h2>
    <p>Call <a href="tel:+1{{ site.defaultPhone }}" data-dynamic-phone-tel><span data-dynamic-phone>{{ site.defaultPhoneFormatted }}</span></a> or fill out the form to get started.</p>
    <a href="#form" class="button">Start Your Claim</a>
  </div>
</section>
{% endblock %}
