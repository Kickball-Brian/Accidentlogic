<nav class="navbar" aria-label="Main">
  <div class="navbar_inner">
    <a href="/" class="navbar_brand">{{ site.name }}</a>
    <button class="navbar_hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <div class="navbar_links">
      <a href="/" class="navbar_link">Home</a>
      {% for s in services %}
      <a href="/{{ s.slug }}" class="navbar_link">{{ s.title }}</a>
      {% endfor %}
    </div>
    <a class="navbar_cta" href="tel:+1{{ site.defaultPhone }}" data-dynamic-phone-tel>
      <span data-dynamic-phone>{{ site.defaultPhoneFormatted }}</span>
    </a>
  </div>
</nav>
